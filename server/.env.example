# ──────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/issue_tracker

# ──────────────────────────────────────────────────────────────
# JWT — generate strong random strings:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-me-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-me-with-another-64-char-random-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=replace-me-with-random-hex
